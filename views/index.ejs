<%- include('partials/header.ejs') %>
<%- include('partials/navbar.ejs') %>

<% if (typeof status !== 'undefined') { %>
    <% if (status === 'added') { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            Product added successfully! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } else if (status === 'updated') { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            Product updated successfully! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } else if (status === 'deleted') { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            Product deleted successfully! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
<% } %>

<div class="container">
    <div class="py-3">
        <h1>Supermarket Inventory</h1>

        <div class="table-responsive">
            <table class="table">
                <% if (products.length > 0) { %>
                    <thead>
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Image</th>
                            <th scope="col">Product Name</th>
                            <th scope="col">Category</th>
                            <th scope="col">Price</th>
                            <th scope="col">Stock</th>
                            <th scope="col">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach((product, index) => { %>
                            <tr>
                                <th scope="row"><%= product.id %></th>
                                <td><img width="100" src="/uploads/<%= product.image %>" class="rounded" alt=""></td>
                                <td><%= product.name %></td>
                                <td><%= product.category %></td>
                                <td><%= product.price %></td>
                                <td><% if (product.stock == 0) { %>
                                <span class="text-danger fw-bold"><%= product.stock %> <span class="badge bg-danger ms-1">Out of Stock</span></span>
                                <% } else { %>
                                <%= product.stock %>
                                <% } %>
                                </td>
                                <td>
                                    <a href="/product/edit/<%= product.id %>" class="btn btn-sm btn-success">Edit</a>
                                    <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="<%= product.id %>">Delete</button>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                <% } else { %>
                    <p class="text-center">No products found. go <a href="/product/add">here</a> to add product.</p>
                <% } %>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                แน่ใจรึป่าวว่าต้องการลบรายการนี้????
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <a id="confirmDeleteBtn" href="#" class="btn btn-danger">Delete</a>
            </div>
        </div>
    </div>
</div>

<script>
    const deleteModal = document.getElementById('deleteModal');
    deleteModal.addEventListener('show.bs.modal', function (event) {
        const button = event.relatedTarget;
        const id = button.getAttribute('data-id');
      
        document.getElementById('confirmDeleteBtn').href = '/product/delete/' + id;
    });
</script>

<%- include('partials/footer.ejs') %>